{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://example.com/loads.schema.json",
  "title": "CargoLoads",
  "description": "Air cargo payloads for A330/B777 solver",
  "oneOf": [
    { "$ref": "#/$defs/PayloadArray" },
    {
      "type": "object",
      "required": ["payload"],
      "additionalProperties": false,
      "properties": {
        "payload": { "$ref": "#/$defs/PayloadArray" },
        "aircraft": {
          "type": "string",
          "enum": ["a330", "b777"]
        }
      }
    }
  ],
  "$defs": {
    "PayloadArray": {
      "type": "array",
      "minItems": 1,
      "maxItems": 200,
      "items": { "$ref": "#/$defs/LoadItem" }
    },
    "LoadItem": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "weight", "type", "door"],
      "properties": {
        "id": { "type": "string", "minLength": 1, "maxLength": 64 },
        "weight": { "type": "number", "exclusiveMinimum": 0 },
        "length": { "type": "number", "exclusiveMinimum": 0 },
        "width":  { "type": "number", "exclusiveMinimum": 0 },
        "height": { "type": "number", "exclusiveMinimum": 0 },
        "type":   { "type": "string", "enum": ["AKE", "PMC", "PAG", "PAL"] },
        "door":   { "type": "string", "enum": ["forward", "aft"] }
      }
    }
  }
}
